{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    },
    "pages/*.php": {
      "runtime": "vercel-php@0.7.2"
    },
    "admin/*.php": {
      "runtime": "vercel-php@0.7.2"
    },
    "index.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    { "src": "/", "dest": "/index.php" },
    { "src": "/pages/(.*)", "dest": "/pages/$1.php" },
    { "src": "/api/(.*)", "dest": "/api/$1.php" },
    { "src": "/admin/(.*)", "dest": "/admin/$1.php" }
  ]
}